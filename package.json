{
  "name": "@quiple/blog-fonts",
  "version": "1.2.1",
  "main": "dist/fonts.css",
  "types": "dist/fonts.d.ts",
  "sass": "src/fonts.sass",
  "style": "dist/fonts.css",
  "exports": {
    ".": {
      "types": "./dist/fonts.d.ts",
      "default": "./dist/fonts.css"
    },
    "./sass": {
      "types": "./src/fonts.d.ts",
      "default": "./src/fonts.sass"
    },
    "./fonts/*": "./fonts/*"
  },
  "files": [
    "dist",
    "src",
    "fonts"
  ],
  "scripts": {
    "build": "sass src/fonts.sass dist/fonts.css && node -e \"require('fs').copyFileSync('src/fonts.d.ts', 'dist/fonts.d.ts')\"",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm publish --access=public",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "fonts",
    "sass",
    "css"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "description": "Font sass and css distribution",
  "devDependencies": {
    "sass": "^1.99.0"
  }
}
